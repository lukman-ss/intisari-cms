APP_NAME=Intisari CMS
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=en
APP_KEY=

DB_CONNECTION=sqlite
DB_DATABASE=database/cms.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=7200
SESSION_COOKIE=intisari_cms_session

CMS_ADMIN_PATH=admin
CMS_SITE_NAME=Intisari CMS
CMS_UPLOAD_DISK=local
CMS_UPLOAD_PATH=storage/uploads
CMS_ITEMS_PER_PAGE=20
