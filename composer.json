{
    "name": "lukman-ss/intisari-cms",
    "description": "A minimal CMS application built on IntisariPHP.",
    "type": "project",
    "keywords": [
        "cms",
        "intisari",
        "php"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Lukman",
            "email": "lukmanumb1@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "lukman-ss/intisari": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "console": "php intisari",
        "serve": "php intisari serve",
        "source:check": "php scripts/check-source-integrity.php"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../intisari",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../session",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../http",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../router",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../container",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../config",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../database",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../view",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../console",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../validation",
            "options": { "symlink": true }
        }
    ]
}
